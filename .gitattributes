# Normalize line endings
* text=auto

# Python and notebooks: LF in repo, platform-native on checkout
*.py    text eol=lf
*.ipynb text eol=lf

# Windows scripts: CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files: no conversion
*.xlsx  binary
*.png   binary
*.jpg   binary
*.pdf   binary
